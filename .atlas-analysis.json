  "keyFeatures": [
    "Role-based authentication and authorization",
    "Product catalog management with images and inventory",
    "Client relationship management (CRM)",
    "Quotation generation with PDF export",
    "Employee management with photo uploads",
    "User and permission management",
    "Calendar and event scheduling",
    "Catalog management (categories, colors, sizes)",
    "Responsive Material-UI interface",
    "Real-time data grids with AG Grid"
  ],
  "publicApiSurface": [
    "Authentication: LoginService, getInfoUser",
    "Products: getProducts, saveProduct, updateProduct, deleteProduct",
    "Clients: getClients, saveClient, updateClient, deleteClient",
    "Quotations: getAdminQuotations, createAdminQuotation, downloadAdminQuotationPdf",
    "Employees: getEmployees, saveEmployee, updateEmployee, deleteEmployee",
    "Users: getUsers, deleteUser",
    "Roles: getRoles, createRole, updateRole, deleteRole",
    "Permissions: getPermissions, createPermission, deletePermission",
    "Catalogs: getCategories, getColors, getSizes, getRegimenFiscal, getCfdi",
    "Inventory: getInventoryByProduct, saveInventory, updateInventory"
  ]
}
